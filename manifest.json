{
  "name": "00_Video Speed Controller",
  "short_name": "videospeed",
  "version": "0.0.0",
  "manifest_version": 3,
  "minimum_chrome_version": "111",
  "description": "Speed up, slow down, advance and rewind HTML5 audio/video with shortcuts",
  "homepage_url": "https://github.com/igrigorik/videospeed",
  "icons": {
    "16": "assets/icons/icon16.png",
    "48": "assets/icons/icon48.png",
    "128": "assets/icons/icon128.png"
  },
  "permissions": ["storage"],
  "options_ui": {
    "page": "ui-react/options-react/index.html",
    "open_in_tab": true
  },
  "action": {
    "default_icon": {
      "19": "assets/icons/icon19.png",
      "38": "assets/icons/icon38.png",
      "48": "assets/icons/icon48.png"
    },
    "default_popup": "ui-react/popup-react/index.html"
  },
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["http://*/*", "https://*/*", "file:///*"],
      "all_frames": true,
      "match_about_blank": true,
      "exclude_matches": ["https://hangouts.google.com/*", "https://meet.google.com/*"],
      "js": ["content-bridge.js"],
      "run_at": "document_start",
      "world": "ISOLATED"
    },
    {
      "matches": ["http://*/*", "https://*/*", "file:///*"],
      "all_frames": true,
      "match_about_blank": true,
      "exclude_matches": ["https://hangouts.google.com/*", "https://meet.google.com/*"],
      "css": ["styles/inject_new.css"],
      "js": ["inject.js"],
      "run_at": "document_idle",
      "world": "MAIN"
    }
  ],
  "web_accessible_resources": [
    {
      "resources": [
        "assets/sounds/beep.oga",
        "assets/sounds/cartoon_blinking_01.oga",
        "assets/sounds/cartoon_blinking_02.oga",
        "assets/sounds/game_start.oga",
        "assets/sounds/new_notification.oga",
        "assets/sounds/pop_01.oga",
        "assets/sounds/pop_02.oga"
      ],
      "matches": ["http://*/*", "https://*/*", "file:///*"]
    }
  ]
}
