{
  "name": "video-speed-controller",
  "version": "0.10.2",
  "description": "Speed up, slow down, advance and rewind HTML5 audio/video with shortcuts",
  "type": "module",
  "scripts": {
    "build": "node scripts/build.mjs && npm run build:react",
    "build:react": "vite build -c vite.react.config.ts",
    "dev": "concurrently -n esbuild,vite -c blue,magenta \"node scripts/build.mjs --watch\" \"npm run dev:react\"",
    "dev:react": "vite build -c vite.react.config.ts --watch",
    "format": "prettier --write src/**/*.js tests/**/*.js",
    "lint": "eslint src/",
    "lint:fix": "eslint src/ --fix",
    "prebuild": "rimraf dist",
    "predev": "rimraf dist",
    "serve": "python3 -m http.server 8000",
    "test": "npm run build && npm run test:unit",
    "test:browser": "echo 'Open tests/fixtures/test-page.html in browser'",
    "test:e2e": "npm run build && node tests/e2e/run-e2e.js",
    "test:integration": "node tests/run-tests.js integration",
    "test:unit": "node tests/run-tests.js unit",
    "tutorials": "npm run tutorials:install && npm --prefix tutorials run dev",
    "tutorials:install": "[ -d tutorials/node_modules ] || npm --prefix tutorials install",
    "tutorials:build": "npm run tutorials:install && npm --prefix tutorials run build",
    "zip": "npm run build && cd dist && zip -r videospeed.zip . && cd .. && echo 'Extension packaged at dist/videospeed.zip'"
  },
  "dependencies": {
    "@popperjs/core": "^2.11.8",
    "bootstrap": "^5.3.8",
    "lodash-es": "^4.18.1",
    "luxon": "^3.7.2",
    "react": "^19.1.1",
    "react-dom": "^19.1.1",
    "react-icons": "^5.5.0"
  },
  "devDependencies": {
    "@crxjs/vite-plugin": "^2.2.0",
    "@eslint/compat": "^1.3.2",
    "@eslint/eslintrc": "^3.3.1",
    "@eslint/js": "^9.35.0",
    "@thedutchcoder/postcss-rem-to-px": "^0.0.2",
    "@trivago/prettier-plugin-sort-imports": "*",
    "@types/chrome": "*",
    "@types/lodash-es": "^4.17.12",
    "@types/node": "^24.3.1",
    "@types/react": "^19.1.12",
    "@types/react-dom": "^19.1.9",
    "@typescript-eslint/eslint-plugin": "*",
    "@typescript-eslint/parser": "*",
    "@vitejs/plugin-react": "^5.2.0",
    "autoprefixer": "^10.4.21",
    "concurrently": "^10.0.3",
    "daisyui": "^5.1.7",
    "date-fns": "^4.1.0",
    "esbuild": "^0.25.9",
    "eslint": "^9.35.0",
    "eslint-plugin-react": "*",
    "eslint-plugin-react-hooks": "*",
    "eslint-plugin-react-refresh": "*",
    "fs-extra": "^11.3.1",
    "globals": "^16.3.0",
    "jsdom": "^26.1.0",
    "postcss": "^8.5.6",
    "postcss-prefix-selector": "^2.1.1",
    "prettier": "^3.6.2",
    "prettier-plugin-tailwindcss": "*",
    "puppeteer": "^24.19.0",
    "rimraf": "^6.0.1",
    "sass": "^1.92.1",
    "tailwindcss": "^4.1.13",
    "typescript": "^5.9.2",
    "vite": "^7.1.4",
    "vite-plugin-eslint": "*"
  },
  "keywords": [
    "video",
    "speed",
    "utils"
  ],
  "author": "Farzad Majidfayyaz",
  "prettier": {
    "singleQuote": true,
    "semi": true,
    "tabWidth": 2,
    "trailingComma": "es5",
    "printWidth": 130
  }
}
